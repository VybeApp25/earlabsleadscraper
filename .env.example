# EAR Labs Scraper — Powered by WeOps — Environment Configuration
# Copy this file to .env and fill in your keys before running.

# ── Required ──────────────────────────────────────────────────────────────────
GOOGLE_PLACES_API_KEY=your_google_places_api_key_here
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# ── Auth ──────────────────────────────────────────────────────────────────────
# Random secret for signing JWT tokens — change this before deploying!
# Generate one: python3 -c "import secrets; print(secrets.token_hex(32))"
AUTH_SECRET_KEY=change-me-to-a-random-secret-at-least-32-chars

# ── Email Provider — choose one ───────────────────────────────────────────────
# Set to "gmail" or "instantly"
EMAIL_PROVIDER=gmail

# Gmail OAuth (if EMAIL_PROVIDER=gmail)
# Setup: https://console.cloud.google.com/apis/library/gmail.googleapis.com
GMAIL_CLIENT_ID=your_gmail_client_id
GMAIL_CLIENT_SECRET=your_gmail_client_secret
GMAIL_REFRESH_TOKEN=your_gmail_refresh_token

# Instantly.ai (if EMAIL_PROVIDER=instantly) — recommended for scale
# Get key: https://app.instantly.ai/app/settings/integrations
INSTANTLY_API_KEY=your_instantly_api_key_here
INSTANTLY_CAMPAIGN_ID=your_instantly_campaign_id_here

# ── GoHighLevel CRM ───────────────────────────────────────────────────────────
# Get: Settings → Integrations → API Keys in GHL
GHL_API_KEY=your_ghl_api_key_here
GHL_LOCATION_ID=your_ghl_location_id_here

# ── Yelp (second lead source) ─────────────────────────────────────────────────
# Get: https://www.yelp.com/developers/v3/manage_app
YELP_API_KEY=your_yelp_fusion_api_key_here

# ── Owner Contact Research ────────────────────────────────────────────────────
# Hunter.io — email finder (free tier: 25 searches/mo)
# Get: https://hunter.io/api-keys
HUNTER_API_KEY=your_hunter_io_api_key_here

# People Data Labs — personal phone + email enrichment
# Get: https://dashboard.peopledatalabs.com/
PDL_API_KEY=your_pdl_api_key_here

# Google Custom Search — web search for owner info (without this, uses DuckDuckGo fallback)
# Get: https://programmablesearchengine.google.com/controlpanel/all
GOOGLE_SEARCH_API_KEY=your_google_custom_search_key_here
GOOGLE_SEARCH_CX=your_custom_search_engine_id_here
